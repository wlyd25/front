                        <Bar dataKey="orders" fill="#8884d8" name="الطلبات" />
                        <Bar dataKey="completed" fill="#82ca9d" name="مكتملة" />
                        <Bar dataKey="cancelled" fill="#ff8042" name="ملغية" />
                      </BarChart>
                    </ResponsiveContainer>
                  </Paper>
                </Grid>
              </Grid>
            )}
          </Box>
        )}
        
        {/* تحليلات الإيرادات */}
        {tabValue === 2 && (
