            ))}
          </TextField>
        </Box>
        
        <Tabs value={tabValue} onChange={handleTabChange} sx={{ mb: 3 }}>
          <Tab label="المستخدمين" />
          <Tab label="الطلبات" />
          <Tab label="الإيرادات" />
