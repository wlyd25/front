                    </CardContent>
                  </Card>
                </Grid>
                <Grid item xs={12} md={4}>
                  <Card>
                    <CardContent>
                      <Typography variant="h4" color="warning.main">
                        {usersAnalytics?.data?.activeUsers?.toLocaleString() || 0}
                      </Typography>
                      <Typography variant="body2">مستخدمين نشطين</Typography>
                    </CardContent>
                  </Card>
                </Grid>
                
                <Grid item xs={12} md={6}>
